<?xml version="1.0" encoding="utf-8"?>
<!-- А-ГОЛОС launcher foreground. Red angular «А» from RodchenkoC SHA,
     extracted as a vector path. Adaptive-icon background = #0B0D16
     via R.color.ic_launcher_background. viewport 108×108dp; the glyph
     stays inside the central 58dp box so OS masks (circle / squircle)
     never clip the letter. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!-- letter-a viewBox 0 0 746 842 (font space, then translate+y-flip
         applied in the inner group). Render into a centred 58dp square. -->
    <group
        android:translateX="25"
        android:translateY="25"
        android:scaleX="0.0777"
        android:scaleY="0.0689">
        <group
            android:translateX="40"
            android:translateY="802"
            android:scaleY="-1">
            <path
                android:fillColor="#F22A37"
                android:pathData="M340,238H256L322,0H0L160,611L238,305H322L203,762H465L666,0H404L340,238Z"/>
        </group>
    </group>
</vector>
