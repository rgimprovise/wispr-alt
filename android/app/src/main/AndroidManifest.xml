<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Core permissions -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Floating overlay over other apps (user must grant in settings) -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Foreground service to keep us alive while overlay is up -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:label="А-ГОЛОС"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:allowBackup="true"
        android:supportsRtl="true"
        android:theme="@style/Theme.WisprAlt">

        <!-- Onboarding / control panel -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Email magic-link / OTP login. Shown on first launch and after
             a 401 from the backend. MainActivity routes here when no
             token is present in AuthStore.
             singleTask + exported so the magic link email's
             agolos://auth?token=... URL routes here whether the app is
             cold or already in foreground; onNewIntent handles re-entry. -->
        <activity
            android:name=".LoginActivity"
            android:exported="true"
            android:launchMode="singleTask">
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="agolos" android:host="auth" />
            </intent-filter>
        </activity>

        <activity
            android:name=".SetPasswordActivity"
            android:exported="false" />

        <!-- Foreground service: owns the overlay + recording lifecycle.
             Started when the user taps the QS tile, notification action,
             or the launcher's "Dictate now" shortcut. -->
        <service
            android:name=".WisprService"
            android:foregroundServiceType="microphone"
            android:exported="false" />

        <!-- Accessibility service: finds the focused EditText in the
             foreground app and inserts the cleaned transcript. -->
        <service
            android:name=".WisprAccessibilityService"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- Quick Settings tile: swipe down twice → tap → starts dictation -->
        <service
            android:name=".WisprTile"
            android:icon="@drawable/ic_status"
            android:label="А-ГОЛОС"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>
    </application>

</manifest>
