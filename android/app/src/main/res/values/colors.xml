    <color name="transcribing">#FF6B7A8F</color>
    <color name="warn">#FFB5803A</color>
    <color name="success">#FF5C7A5A</color>
    <color name="error">#FF8E3A3A</color>

    <!-- Launcher icon background (paper-soft for adaptive icon) -->
    <color name="ic_launcher_background">#FFF4F1EC</color>
</resources>
