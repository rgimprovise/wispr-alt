OPENAI_API_KEY=sk-...
PORT=8787

# Auth — required in prod. JWT_SECRET must be ≥32 chars.
# Generate with: openssl rand -base64 48
AUTH_JWT_SECRET=change-me-to-a-long-random-string-min-32-chars

# Resend (https://resend.com) — magic-link delivery.
# If RESEND_API_KEY is unset, emails are logged to stdout (dev mode).
RESEND_API_KEY=re_...
RESEND_FROM=Беловик <noreply@belovik.app>

# Public URL of this backend, used inside email magic links.
APP_URL=https://belovik.app

# SQLite path. In prod via docker-compose this is overridden to /data/wispr.db.
DB_PATH=./data/wispr.db
